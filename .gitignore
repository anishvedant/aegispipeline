# Terraform working directories and state
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
*.tfplan
crash.log
crash.*.log

# Keep Terraform dependency lock files in version control
# .terraform.lock.hcl is intentionally NOT ignored.

# Kubernetes credentials and local connection files
**/kubeconfig
**/k3s.yaml

# Secrets and local environment
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.ovpn

# Generated top-level reports (selected evidence files already tracked remain tracked)
reports/*.json
reports/*.md
reports/*.txt
!reports/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
venv/

# Local notes and editor files
notes/
.vscode/
.idea/
.DS_Store

# Exporter runtime files
monitoring/exporter.log
monitoring/exporter.pid
